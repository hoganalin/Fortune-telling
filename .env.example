# Required for the /api/reading Vercel serverless function.
# Get yours at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Optional — override the default model (claude-opus-4-7).
# Examples: claude-sonnet-4-6 (cheaper, still strong), claude-opus-4-6
# ANTHROPIC_MODEL=claude-opus-4-7
